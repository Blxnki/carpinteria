---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center bg-stone-200">
  <div class="absolute inset-0">
    <img
      src="/images/hero/hero-background.jpg"
      alt="Workshop"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <div class="relative z-10 text-center text-white p-4">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-bold mb-4 drop-shadow-md">
      {t('hero.title')}
    </h1>
    <p class="text-lg md:text-xl lg:text-2xl max-w-2xl mx-auto mb-8 drop-shadow">
      {t('hero.subtitle')}
    </p>
    <a href="#contacto" class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-3 px-8 rounded-lg text-lg transition-transform duration-300 transform hover:scale-105">
      {t('hero.cta')}
    </a>
  </div>
</section>
