---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Dark Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/carpinteria/hammer.jpg"
      alt="Carpintería Familiar"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/60 dark:bg-black/70 transition-colors duration-300"></div>
  </div>

  <div class="relative z-10 text-center max-w-3xl mx-auto p-6 md:p-8">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-amber-400 mb-3 md:mb-4 drop-shadow-sm">
      {lang === 'es' ? 'Alta Carpintería' : 'Premium Woodwork'}
    </span>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-bold mb-6 text-white leading-tight drop-shadow-md">
      {t('hero.title')}
    </h1>
    <p class="text-lg md:text-xl lg:text-2xl text-stone-200 max-w-2xl mx-auto mb-10 leading-relaxed drop-shadow">
      {t('hero.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
      <a href="#contacto" class="w-full sm:w-auto bg-amber-600 hover:bg-amber-700 text-white font-bold py-3.5 px-8 rounded-lg text-lg transition-all duration-300 transform hover:scale-105 shadow-lg shadow-black/30">
        {t('hero.cta')}
      </a>
      <a href="#servicios" class="w-full sm:w-auto border border-white/40 hover:border-white text-white hover:bg-white/10 font-bold py-3.5 px-8 rounded-lg text-lg transition-all duration-300 backdrop-blur-sm">
        {lang === 'es' ? 'Ver Servicios' : 'View Services'}
      </a>
    </div>
  </div>
</section>
