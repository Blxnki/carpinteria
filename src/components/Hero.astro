---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-stone-100 via-stone-50 to-amber-50/40 dark:from-stone-950 dark:via-stone-900 dark:to-amber-950/20 transition-colors duration-300 overflow-hidden">
  <!-- Subtle decorative wood grain pattern overlay (Optional visual touch) -->
  <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.03] pointer-events-none bg-repeat bg-center" style="background-image: url('/favicon.svg'); background-size: 80px;"></div>

  <div class="relative z-10 text-center max-w-3xl mx-auto p-6 md:p-8">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-amber-600 dark:text-amber-500 mb-3 md:mb-4">
      {lang === 'es' ? 'Alta Carpintería' : 'Premium Woodwork'}
    </span>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-bold mb-6 text-stone-900 dark:text-stone-100 leading-tight transition-colors duration-300">
      {t('hero.title')}
    </h1>
    <p class="text-lg md:text-xl lg:text-2xl text-stone-600 dark:text-stone-300 max-w-2xl mx-auto mb-10 leading-relaxed transition-colors duration-300">
      {t('hero.subtitle')}
    </p>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
      <a href="#contacto" class="w-full sm:w-auto bg-amber-600 hover:bg-amber-700 text-white font-bold py-3.5 px-8 rounded-lg text-lg transition-all duration-300 transform hover:scale-105 shadow-md shadow-amber-600/20 hover:shadow-lg">
        {t('hero.cta')}
      </a>
      <a href="#servicios" class="w-full sm:w-auto border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-stone-800/50 font-bold py-3.5 px-8 rounded-lg text-lg transition-all duration-300">
        {lang === 'es' ? 'Ver Servicios' : 'View Services'}
      </a>
    </div>
  </div>
</section>
