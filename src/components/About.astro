---
import SectionTitle from "./ui/SectionTitle.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="sobre-nosotros" class="py-20 bg-stone-100 dark:bg-stone-900/50 transition-colors duration-300">
  <div class="container mx-auto px-4">
    <SectionTitle
      title={t('about.title')}
      subtitle={t('about.subtitle')}
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        <h3 class="text-2xl font-bold mb-4 text-stone-900 dark:text-stone-100">{t('about.title')}</h3>
        <p class="mb-4 text-stone-600 dark:text-stone-300">
          {t('about.content1')}
        </p>
        <p class="mb-6 text-stone-600 dark:text-stone-300">
          {t('about.content2')}
        </p>
        <a href="#contacto" class="inline-block bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 px-6 rounded-lg transition-transform duration-300 transform hover:scale-105">
          {t('about.cta')}
        </a>
      </div>
      <div class="order-1 md:order-2">
        <img
          src="/images/carpinteria/cam.jpeg"
          alt="Carpintería Familiar"
          class="rounded-lg shadow-xl w-full h-auto object-cover border border-transparent dark:border-stone-800"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
