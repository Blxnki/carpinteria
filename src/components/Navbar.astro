---
import { SITE_TITLE } from '../consts';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { name: t('nav.inicio'), href: '#inicio' },
  { name: t('nav.servicios'), href: '#servicios' },
  { name: t('nav.galeria'), href: '#galeria' },
  { name: t('nav.sobre'), href: '#sobre-nosotros' },
  { name: t('nav.testimonios'), href: '#testimonios' },
  { name: t('nav.contacto'), href: '#contacto' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent">
  <div class="container mx-auto px-4">
    <nav class="flex items-center justify-between py-4">
      <a href={lang === 'es' ? '/' : `/${lang}/`} class="text-2xl font-bold text-stone-900 dark:text-stone-100 transition-colors">{SITE_TITLE}</a>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-6">
        {navLinks.map(link => (
          <a href={link.href} class="text-stone-600 dark:text-stone-300 hover:text-stone-900 dark:hover:text-stone-100 transition-colors font-medium">{link.name}</a>
        ))}
      </div>

      <div class="flex items-center space-x-4">
        <LanguagePicker />
        <ThemeToggle />

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-button" class="md:hidden p-2 text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-200 focus:outline-none focus:ring-2 focus:ring-stone-500 rounded-lg">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-stone-50 dark:bg-stone-900 transform -translate-y-full transition-transform duration-300 ease-in-out md:hidden flex items-center justify-center">
  <div class="flex flex-col items-center justify-center space-y-6">
    {navLinks.map(link => (
      <a href={link.href} class="text-2xl text-stone-800 dark:text-stone-200 hover:text-amber-600 dark:hover:text-amber-500 mobile-menu-link font-medium">{link.name}</a>
    ))}
  </div>
</div>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('-translate-y-full');
  });

  mobileMenuLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('-translate-y-full');
    });
  });

  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-white/90', 'dark:bg-stone-950/90', 'backdrop-blur-md', 'shadow-md', 'border-stone-200/50', 'dark:border-stone-800/50');
      header?.classList.remove('border-transparent');
    } else {
      header?.classList.remove('bg-white/90', 'dark:bg-stone-950/90', 'backdrop-blur-md', 'shadow-md', 'border-stone-200/50', 'dark:border-stone-800/50');
      header?.classList.add('border-transparent');
    }
  });
</script>
