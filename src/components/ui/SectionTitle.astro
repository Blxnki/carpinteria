---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-3xl md:text-4xl font-bold font-serif text-stone-900 dark:text-stone-100 transition-colors">{title}</h2>
  <p class="text-lg text-stone-600 dark:text-stone-300 mt-2 max-w-2xl mx-auto transition-colors">{subtitle}</p>
  <div class="mt-4 w-24 h-1 bg-amber-600 mx-auto rounded"></div>
</div>
